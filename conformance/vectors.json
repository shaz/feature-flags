        "enabled": true, "offVariation": 1,
        "rules": [
          {"clauses": [{"contextKind": "user", "attribute": "key", "op": "segmentMatch", "values": ["power-viewers"]}], "variation": 0}
        ],
        "fallthrough": {"variation": 1}
      }
    },
    "segments": [
      {"key": "power-viewers", "contextKind": "user", "included": ["u-vip"], "excluded": [], "rules": []}

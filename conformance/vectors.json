[
  {
    "name": "flag off serves offVariation",
    "flag": {
      "key": "f-off", "salt": "s1", "kind": "boolean",
      "variations": [{"name": "On", "value": true}, {"name": "Off", "value": false}],
      "config": {
        "enabled": false, "offVariation": 1,
        "fallthrough": {"variation": 0}
      }
    },
    "context": {"kind": "user", "key": "anyone"},
    "expected": {"variationIndex": 1, "value": false, "reason": "OFF"}
  },
  {
    "name": "enabled, no rules -> fallthrough",
    "flag": {
      "key": "f-fall", "salt": "s1", "kind": "boolean",
      "variations": [{"name": "On", "value": true}, {"name": "Off", "value": false}],
      "config": {"enabled": true, "offVariation": 1, "fallthrough": {"variation": 0}}
    },
    "context": {"kind": "user", "key": "anyone"},
    "expected": {"variationIndex": 0, "value": true, "reason": "FALLTHROUGH"}
  },
  {
    "name": "individual target match wins over fallthrough",
    "flag": {
      "key": "f-target", "salt": "s1", "kind": "boolean",
      "variations": [{"name": "On", "value": true}, {"name": "Off", "value": false}],
      "config": {
        "enabled": true, "offVariation": 1,
        "targets": [{"contextKind": "user", "variation": 1, "keys": ["u-block"]}],
        "fallthrough": {"variation": 0}
      }
    },
    "context": {"kind": "user", "key": "u-block"},
    "expected": {"variationIndex": 1, "value": false, "reason": "TARGET_MATCH"}
  },
  {
    "name": "rule with 'in' clause matches (user.country)",
    "flag": {
      "key": "f-rule", "salt": "s1", "kind": "boolean",
      "variations": [{"name": "On", "value": true}, {"name": "Off", "value": false}],
      "config": {
        "enabled": true, "offVariation": 1,
        "rules": [
          {"clauses": [{"contextKind": "user", "attribute": "country", "op": "in", "values": ["US", "CA"]}], "variation": 0}
        ],
        "fallthrough": {"variation": 1}
      }
    },
    "context": {"kind": "user", "key": "u1", "country": "US"},
    "expected": {"variationIndex": 0, "value": true, "reason": "RULE_MATCH"}
  },
  {
    "name": "rule does not match -> fallthrough",
    "flag": {
      "key": "f-rule", "salt": "s1", "kind": "boolean",
      "variations": [{"name": "On", "value": true}, {"name": "Off", "value": false}],
      "config": {
        "enabled": true, "offVariation": 1,
        "rules": [
          {"clauses": [{"contextKind": "user", "attribute": "country", "op": "in", "values": ["US", "CA"]}], "variation": 0}
        ],
        "fallthrough": {"variation": 1}
      }
    },
    "context": {"kind": "user", "key": "u1", "country": "MX"},
    "expected": {"variationIndex": 1, "value": false, "reason": "FALLTHROUGH"}
  },
  {
    "name": "segmentMatch clause (included key)",
